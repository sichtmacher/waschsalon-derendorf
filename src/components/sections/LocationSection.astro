---
import GoogleMap from '../GoogleMap.astro';
// Per D-20/D-24 and UI-SPEC Copywriting Contract lines 140-144.
// Telephone: +49 211 54202673 (NAP)
// Email: info@waschsalon-derendorf.de
// Address: Münsterstr. 88 · 40477 Düsseldorf
---

<section
  id="kontakt"
  class="py-12 md:py-20 px-4"
  style="background-color: #FFFFFF; scroll-margin-top: 4.5rem;"
  aria-labelledby="kontakt-heading"
>
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-10 md:mb-12">
      <h2
        id="kontakt-heading"
        class="text-2xl md:text-[2rem] font-semibold mb-3"
        style="color: var(--color-text); font-family: var(--font-heading), var(--font-body), sans-serif; line-height: 1.2;"
      >
        So findest du uns
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10 items-start">
      <div class="space-y-5">
        <div>
          <p class="text-lg font-semibold mb-1" style="color: var(--color-text);">
            Münsterstr. 88 · 40477 Düsseldorf
          </p>
          <p class="text-base" style="color: var(--color-text);">
            Direkt mit U-Bahn, Bus oder Auto erreichbar. Straßenparkplätze vor dem Salon, Parkhaus in der Nähe.
          </p>
        </div>

        <dl class="space-y-3">
          <div class="flex items-center gap-3">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="stroke: var(--color-brand);"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <dt class="sr-only">Telefon</dt>
            <dd>
              <a href="tel:+4921154202673" class="text-sm font-semibold underline-offset-4 hover:underline transition-colors" style="color: var(--color-brand);" aria-label="Telefon: +49 211 54202673">
                +49 211 54202673
              </a>
            </dd>
          </div>
          <div class="flex items-center gap-3">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="stroke: var(--color-brand);"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <dt class="sr-only">E-Mail</dt>
            <dd>
              <a href="mailto:info@waschsalon-derendorf.de" class="text-sm font-semibold underline-offset-4 hover:underline transition-colors" style="color: var(--color-brand);" aria-label="E-Mail: info@waschsalon-derendorf.de">
                info@waschsalon-derendorf.de
              </a>
            </dd>
          </div>
        </dl>
      </div>

      <div class="rounded-2xl overflow-hidden shadow-sm" style="border: 1px solid rgba(0,0,0,0.06);">
        <GoogleMap address="Münsterstr. 88, 40477 Düsseldorf" />
      </div>
    </div>
  </div>
</section>

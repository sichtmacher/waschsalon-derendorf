---
// Öffnungszeiten — sits on the alternating surface stripe per UI-SPEC Color allocation.
// Includes a "Heute geöffnet" status pill that computes open/closed client-side from current time.
// Hours locked per D-14: Mo-So 06:00-22:00.
---

<section
  id="oeffnungszeiten"
  class="py-12 md:py-20 px-4"
  style="background-color: var(--color-surface); scroll-margin-top: 4.5rem;"
  aria-labelledby="oeffnungszeiten-heading"
>
  <div class="max-w-3xl mx-auto text-center">
    <h2
      id="oeffnungszeiten-heading"
      class="text-2xl md:text-[2rem] font-semibold mb-3"
      style="color: var(--color-text); font-family: var(--font-heading), var(--font-body), sans-serif; line-height: 1.2;"
    >
      Täglich für dich geöffnet
    </h2>
    <p class="text-lg md:text-xl mb-6" style="color: var(--color-text);">
      Montag bis Sonntag · 06:00 – 22:00 Uhr
    </p>

    <div
      id="today-status"
      class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold"
      style="background-color: var(--color-brand-light); color: var(--color-brand-dark);"
      data-open="06:00"
      data-close="22:00"
    >
      <span class="inline-block w-2 h-2 rounded-full" style="background-color: var(--color-brand);" aria-hidden="true"></span>
      <span data-status-label>Öffnungszeiten</span>
    </div>
  </div>
</section>

<script>
  // Compute whether the salon is currently open and update the pill label.
  // Runs once on load; no interval — no layout thrash.
  const pill = document.getElementById('today-status');
  if (pill) {
    const now = new Date();
    const currentMinutes = now.getHours() * 60 + now.getMinutes();
    const openMinutes = 6 * 60;   // 06:00
    const closeMinutes = 22 * 60; // 22:00
    const label = pill.querySelector('[data-status-label]');
    if (label) {
      label.textContent = currentMinutes >= openMinutes && currentMinutes < closeMinutes
        ? 'Heute geöffnet'
        : 'Gerade geschlossen — morgen ab 06:00';
    }
  }
</script>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import GoogleMap from "../components/GoogleMap.astro";
---

<BaseLayout description="Waschsalon Derendorf -- Dein neuer SB-Waschsalon in Duesseldorf. Eroeffnung 2026.">

  <!-- Hero Section with gradient and bubbles -->
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #0891B2 0%, #0E7490 40%, #065F73 100%);">
    <!-- Decorative bubbles -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="bubble"></div>
      <div class="bubble"></div>
      <div class="bubble"></div>
      <div class="bubble"></div>
      <div class="bubble"></div>
      <div class="bubble"></div>
      <div class="bubble"></div>
      <div class="bubble"></div>
    </div>

    <div class="relative z-10 px-4 py-20 sm:py-28 text-center">
      <div class="max-w-xl mx-auto">

        <!-- Washer icon -->
        <div class="mb-6 inline-flex items-center justify-center w-20 h-20 rounded-full" style="background: rgba(255,255,255,0.15); backdrop-filter: blur(10px);">
          <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="2" width="18" height="20" rx="2" />
            <circle cx="12" cy="13" r="5" />
            <path d="M9.5 12.5c1 -1 2.5 -1 3.5 0s2.5 1 3.5 0" opacity="0.7" />
            <circle cx="7" cy="6" r="1" fill="white" stroke="none" />
            <circle cx="10" cy="6" r="1" fill="white" stroke="none" />
          </svg>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white tracking-tight mb-4" style="font-family: var(--font-heading), var(--font-body), sans-serif;">
          Waschsalon Derendorf
        </h1>
        <p class="text-lg sm:text-xl text-white/85 mb-2" style="font-family: var(--font-heading), var(--font-body), sans-serif;">
          Dein neuer SB-Waschsalon in Derendorf
        </p>
        <p class="text-sm text-white/60">
          Self-service laundromat &mdash; Opening 2026
        </p>
      </div>
    </div>

    <!-- Wave separator -->
    <div class="relative" style="height: 60px;">
      <svg class="absolute bottom-0 w-full" viewBox="0 0 1200 60" preserveAspectRatio="none" style="height: 60px;">
        <path d="M0,60 L0,30 Q300,0 600,30 Q900,60 1200,30 L1200,60 Z" fill="#FAFFFE" />
      </svg>
    </div>
  </section>

  <!-- Content Section -->
  <section class="px-4 pb-16 -mt-2" style="background-color: #FAFFFE;">
    <div class="max-w-lg mx-auto space-y-6">

      <!-- Opening announcement card -->
      <div class="rounded-2xl shadow-lg overflow-hidden transform -translate-y-8" style={`background: linear-gradient(135deg, var(--color-accent-light), #FFF7ED);`}>
        <div class="px-6 py-5 text-center">
          <div class="inline-flex items-center gap-2 mb-1">
            <span class="text-2xl" role="img" aria-label="Feier">&#127881;</span>
            <span class="text-xl font-bold" style={`color: var(--color-text); font-family: var(--font-heading), var(--font-body), sans-serif;`}>
              Eroeffnung 2026
            </span>
            <span class="text-2xl" role="img" aria-label="Feier">&#127881;</span>
          </div>
          <p class="text-sm" style={`color: var(--color-text-muted);`}>Wir freuen uns auf dich!</p>
        </div>
      </div>

      <!-- Address card -->
      <div class="rounded-2xl p-6 shadow-sm border" style={`background: white; border-color: #E2E8F0;`}>
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center" style={`background-color: var(--color-surface);`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style={`stroke: var(--color-brand);`}>
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
          </div>
          <div>
            <h2 class="font-semibold mb-1" style={`color: var(--color-text); font-family: var(--font-heading), var(--font-body), sans-serif;`}>Adresse</h2>
            <p style={`color: var(--color-text-muted);`}>Muensterstr. 88</p>
            <p style={`color: var(--color-text-muted);`}>40625 Duesseldorf</p>
          </div>
        </div>
      </div>

      <!-- Email card -->
      <div class="rounded-2xl p-6 shadow-sm border" style={`background: white; border-color: #E2E8F0;`}>
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center" style={`background-color: var(--color-surface);`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style={`stroke: var(--color-brand);`}>
              <rect width="20" height="16" x="2" y="4" rx="2" />
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
            </svg>
          </div>
          <div>
            <h2 class="font-semibold mb-1" style={`color: var(--color-text); font-family: var(--font-heading), var(--font-body), sans-serif;`}>Kontakt</h2>
            <a href="mailto:info@waschsalon-derendorf.de"
               class="transition-colors hover:underline"
               style={`color: var(--color-brand);`}>
              info@waschsalon-derendorf.de
            </a>
          </div>
        </div>
      </div>

      <!-- Map section -->
      <div class="rounded-2xl overflow-hidden shadow-sm border" style="border-color: #E2E8F0;">
        <GoogleMap address="Muensterstr. 88, 40625 Duesseldorf" />
      </div>

    </div>
  </section>

</BaseLayout>

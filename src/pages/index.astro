---
import BaseLayout from "../layouts/BaseLayout.astro";
import GoogleMap from "../components/GoogleMap.astro";
import WarpBackground from "../components/WarpBackground.tsx";
---

<BaseLayout description="Waschsalon Derendorf -- Dein neuer SB-Waschsalon in Duesseldorf. Eroeffnung 2026.">

  <!-- Full-page hero with shader background -->
  <section class="relative min-h-screen overflow-hidden">
    <div class="absolute inset-0">
      <WarpBackground client:load />
    </div>

    <div class="relative z-10 px-4 py-12 sm:py-16 min-h-screen flex flex-col items-center justify-center">
      <div class="max-w-xl mx-auto text-center space-y-6">

        <!-- Washer icon -->
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full" style="background: rgba(255,255,255,0.15); backdrop-filter: blur(10px);">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="2" width="18" height="20" rx="2" />
            <circle cx="12" cy="13" r="5" />
            <path d="M9.5 12.5c1 -1 2.5 -1 3.5 0s2.5 1 3.5 0" opacity="0.7" />
            <circle cx="7" cy="6" r="1" fill="white" stroke="none" />
            <circle cx="10" cy="6" r="1" fill="white" stroke="none" />
          </svg>
        </div>

        <!-- Title -->
        <div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white tracking-tight mb-2" style="font-family: var(--font-heading), var(--font-body), sans-serif;">
            Waschsalon Derendorf
          </h1>
          <p class="text-lg sm:text-xl text-white/85" style="font-family: var(--font-heading), var(--font-body), sans-serif;">
            Dein neuer SB-Waschsalon in Derendorf
          </p>
        </div>

        <!-- Opening badge -->
        <div class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-white font-semibold text-lg" style="background: rgba(255,255,255,0.2); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.3); font-family: var(--font-heading), var(--font-body), sans-serif;">
          <span role="img" aria-label="Feier">&#127881;</span>
          Eroeffnung 2026
          <span role="img" aria-label="Feier">&#127881;</span>
        </div>

        <!-- Info row: Address + Email -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center items-center pt-2">
          <div class="flex items-center gap-2 px-4 py-2.5 rounded-xl text-white/90 text-sm" style="background: rgba(255,255,255,0.12); backdrop-filter: blur(8px);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            Muensterstr. 88, 40477 Duesseldorf
          </div>
          <a href="mailto:info@waschsalon-derendorf.de" class="flex items-center gap-2 px-4 py-2.5 rounded-xl text-white/90 text-sm hover:text-white transition-colors" style="background: rgba(255,255,255,0.12); backdrop-filter: blur(8px);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2" />
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
            </svg>
            info@waschsalon-derendorf.de
          </a>
        </div>

        <p class="text-xs text-white/50 pt-1">
          Self-service laundromat &mdash; Opening 2026
        </p>

      </div>

      <!-- Map at bottom of hero -->
      <div class="w-full max-w-lg mx-auto mt-8 rounded-2xl overflow-hidden shadow-lg" style="border: 1px solid rgba(255,255,255,0.2);">
        <GoogleMap address="Muensterstr. 88, 40477 Duesseldorf" />
      </div>
    </div>
  </section>

</BaseLayout>
